<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:id="@+id/tabsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/friendsCount"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/photoTab"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Фото"
            android:backgroundTint="@android:color/transparent"
            android:textColor="@android:color/black"
            android:textSize="14sp"
            android:drawableTop="@drawable/photo_icon"
            android:drawablePadding="4dp"
            android:padding="8dp"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/videoTab"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Видео"
            android:backgroundTint="@android:color/transparent"
            android:textColor="@android:color/black"
            android:textSize="14sp"
            android:drawableTop="@drawable/video_icon"
            android:drawablePadding="4dp"
            android:padding="8dp"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/musicTab"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Музыка"
            android:backgroundTint="@android:color/transparent"
            android:textColor="@android:color/black"
            android:textSize="14sp"
            android:drawableTop="@drawable/music_icon"
            android:drawablePadding="4dp"
            android:padding="8dp"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/otherTab"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Альбомы"
            android:backgroundTint="@android:color/transparent"
            android:textColor="@android:color/black"
            android:textSize="14sp"
            android:drawableTop="@drawable/album_icon"
            android:drawablePadding="4dp"
            android:padding="8dp"
            android:stateListAnimator="@null"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>